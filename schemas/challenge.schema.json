{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainativecitizens.badita.org/schemas/challenge.schema.json",
  "title": "AI-Native Citizens Challenge",
  "type": "object",
  "required": ["id", "title", "problem", "user", "why_it_matters", "possible_data_sources", "mvp_scope", "difficulty", "workflow_cards", "demo_examples", "continuation_path"],
  "properties": {
    "id": {"type": "string", "pattern": "^CH-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 3},
    "problem": {"type": "string", "minLength": 10},
    "user": {"type": "string", "minLength": 10},
    "why_it_matters": {"type": "string", "minLength": 10},
    "possible_data_sources": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "mvp_scope": {"type": "string", "minLength": 10},
    "difficulty": {"enum": ["Easy", "Medium", "Hard"]},
    "workflow_cards": {"type": "array", "items": {"type": "string", "pattern": "^WF-[0-9]{2}$"}, "minItems": 1},
    "demo_examples": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "continuation_path": {"type": "string", "minLength": 10}
  },
  "additionalProperties": false
}

