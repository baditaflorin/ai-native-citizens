{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainativecitizens.badita.org/schemas/workflow-card.schema.json",
  "title": "AI-Native Citizens Workflow Card",
  "type": "object",
  "required": ["id", "title", "what_it_does", "when_to_use", "tools", "prompt_skeleton", "failure_modes", "verify"],
  "properties": {
    "id": {"type": "string", "pattern": "^WF-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 3},
    "what_it_does": {"type": "string", "minLength": 10},
    "when_to_use": {"type": "string", "minLength": 10},
    "tools": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "prompt_skeleton": {"type": "string", "minLength": 10},
    "failure_modes": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "verify": {"type": "string", "minLength": 10}
  },
  "additionalProperties": false
}

